<?xml version="1.0" encoding="utf-8"?>
<!-- BlockX launch screen: dark background so the native launch/splash matches the
     Flutter splash (dark #080808 + logo) with no jarring black/white flash. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/blockx_dark" />
    <item>
        <bitmap
            android:gravity="center"
            android:src="@mipmap/ic_launcher" />
    </item>
</layer-list>
